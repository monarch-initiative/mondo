```yaml
name: "ClinGen new gene-disease term request"
labels:
  - ClinGen
  - New term request
data:
  submitters:{% for s in submitters %}
    - "{{ s }}"{% endfor %}
  gene_name: "{{ gene_name }}"
  hgnc_id: "{{ hgnc_id }}"
  gene_disease_refs:{% for r in gene_disease_refs %}
    - "{{ r }}"{% endfor %}
  parents:{% for parent in parents %}
    - label: "{{ parent.label }}"
      id: "{{ parent.id }}"{% if parent.ref is defined and parent.ref %}
      ref: "{{ parent.ref }}"{% endif %}{% endfor %}
  term_label: "{{ term_label }}"{% if synonyms is defined and synonyms %}
  synonyms:{% for s in synonyms %}
    - "{{ s }}"{% endfor %}{% endif %}{% if label_refs is defined and label_refs %}
  label_refs:{% for r in label_refs %}
    - "{{ r }}"{% endfor %}{% endif %}{% if definition is defined and definition %}
  definition: "{{ definition | replace('"', '\\"') }}"{% endif %}{% if definition_refs is defined and definition_refs %}
  definition_refs:{% for r in definition_refs %}
    - "{{ r }}"{% endfor %}{% endif %}{% if xrefs is defined and xrefs %}
  xrefs:{% for x in xrefs %}
    - "{{ x }}"{% endfor %}{% endif %}{% if children is defined and children %}
  children:{% for child in children %}
    - label: "{{ child.label }}"
      id: "{{ child.id }}"{% if child.ref is defined and child.ref %}
      ref: "{{ child.ref }}"{% endif %}{% endfor %}{% endif %}{% if comments is defined and comments %}
  comments: "{{ comments | replace('"', '\\"') | replace('\n', '\\n') }}"{% endif %}
```

